{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/game/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Nunito))/i]",
        "message": "Font not provided by the design system. Available: Nunito."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|solid|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, solid, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|blue|yellow|purple|red|cyan)$/]",
        "message": "<Badge> tone must be one of 'green' | 'blue' | 'yellow' | 'purple' | 'red' | 'cyan'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|active|block|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, active, block, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|neutral|active|danger|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'neutral' | 'active' | 'danger' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CollectionItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|collected|count|style|key|ref|className|style|children)$/]",
        "message": "<CollectionItem> doesn't accept that prop. Declared props: name, collected, count, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|accent|width|solid|glow|style|children|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: title, accent, width, solid, glow, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:yellow|green|blue|purple|red|cyan)$/]",
        "message": "<Panel> accent must be one of 'yellow' | 'green' | 'blue' | 'purple' | 'red' | 'cyan'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|tone|label|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, max, tone, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|blue|yellow)$/]",
        "message": "<ProgressBar> tone must be one of 'green' | 'blue' | 'yellow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuizOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|selected|state|onClick|style|key|ref|className|style|children)$/]",
        "message": "<QuizOption> doesn't accept that prop. Declared props: children, selected, state, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuizOption'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:correct|wrong)$/]",
        "message": "<QuizOption> state must be one of 'correct' | 'wrong'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<SegmentedControl> doesn't accept that prop. Declared props: options, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|tone|valueColor|style|key|ref|className|style|children)$/]",
        "message": "<StatRow> doesn't accept that prop. Declared props: label, value, tone, valueColor, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatRow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|player|credits|streak|prizes|accuracy)$/]",
        "message": "<StatRow> tone must be one of 'default' | 'player' | 'credits' | 'streak' | 'prizes' | 'accuracy'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
